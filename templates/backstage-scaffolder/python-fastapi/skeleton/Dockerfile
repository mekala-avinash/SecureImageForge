# {{service_name}}
# (Generated by `pavedroad new service`. Hardened multi-arch image.)
# Builder + runtime are split; runtime stage is distroless.
# This is a thin wrapper around the canonical /app/images/runtimes/python/Dockerfile.

# syntax=docker/dockerfile:1.7
ARG PYTHON_VERSION=3.12

FROM cgr.dev/chainguard/python:${PYTHON_VERSION}-dev AS builder
WORKDIR /build
ENV PIP_NO_CACHE_DIR=1 PIP_DISABLE_PIP_VERSION_CHECK=1 VIRTUAL_ENV=/opt/venv
RUN python -m venv ${VIRTUAL_ENV}
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"
COPY requirements.txt requirements.lock ./
RUN --mount=type=cache,target=/root/.cache/pip pip install --no-deps --require-hashes -r requirements.lock
COPY src/ ./app/
ENV SOURCE_DATE_EPOCH=0
RUN python -m compileall -q -j 0 ${VIRTUAL_ENV} /build/app

FROM cgr.dev/chainguard/python:${PYTHON_VERSION} AS runtime
ARG SERVICE_NAME={{service_name}}
ARG VERSION
LABEL org.opencontainers.image.title="${SERVICE_NAME}" org.opencontainers.image.version="${VERSION}"
WORKDIR /app
ENV PATH=/opt/venv/bin:$PATH PYTHONUNBUFFERED=1 PORT=8080 TZ=UTC
COPY --from=builder --chown=65532:65532 /opt/venv /opt/venv
COPY --from=builder --chown=65532:65532 /build/app /app/app
USER 65532:65532
EXPOSE 8080
STOPSIGNAL SIGTERM
ENTRYPOINT ["/opt/venv/bin/python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "2"]
